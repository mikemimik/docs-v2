          },
          {
            "href": "https://support.auth0.com",
            "label": "Help"
          },
          {
            "href": "https://auth0.com/docs/troubleshoot",
            "label": "FAQs"
          },
          {
            "href": "https://auth0.com",
            "label": "Auth0"
          }
