{
  "$schema": "https://mintlify.com/docs.json",
  "api": {
    "params": {
      "post": [
        "x-release-lifecycle"
      ]
    },
    "playground": {
      "proxy": false
    },
    "url": "full"
  },
  "background": {
    "decoration": "gradient"
  },
  "colors": {
    "dark": "#343434",
    "light": "#B3A7FF",
    "primary": "#7549F2"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "description": "Auth0 documentation",
  "favicon": "/docs/images/logo/favicon.svg",
  "fonts": {
    "body": {
      "family": "Inter",
      "format": "woff2",
      "source": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
    }
  },
  "footer": {
