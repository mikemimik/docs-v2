{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Auth0 Docs",
  "description": "Auth0 documentation",
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "seo": {
    "metatags": {
      "canonical": "https://auth0.com",
      "og:image": "docs/images/share-image.png"
    }
  },
  "colors": {
    "primary": "#7549F2",
    "light": "#B3A7FF",
    "dark": "#343434"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "fonts": {
    "body": {
      "family": "Inter",
      "source": "https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap",
      "format": "woff2"
    }
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-W7FRLJ"
    }
  },
  "api": {
    "url": "full",
    "playground": {
      "proxy": false
    },
    "params": {
      "post": ["x-release-lifecycle"]
    }
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "pages": [
          "docs/index"
        ]
      },
      {
        "tab": "Get Started",
        "icon": "play",
        "$ref": "config/navigation/get-started.json"
      },
      {
        "tab": "Authenticate",
        "icon": "/icons/authenticate.svg",
        "$ref": "config/navigation/authenticate.json"
      },
      {
        "tab": "Manage Users",
        "icon": "/icons/manage-users.svg",
        "$ref": "config/navigation/manage-users.json"
      },
      {
        "tab": "Customize",
        "icon": "/icons/customize.svg",
        "$ref": "config/navigation/customize.json"
      },
      {
        "tab": "Secure",
        "icon": "shield-check",
        "$ref": "config/navigation/secure.json"
      },
      {
        "tab": "Deploy & Monitor",
        "icon": "chart-simple",
        "$ref": "config/navigation/deploy-and-monitor.json"
      },
      {
        "tab": "Auth0 AI",
        "icon": "/icons/auth0-ai.svg",
        "$ref": "config/navigation/ai.json"
      },
      {
        "tab": "Platform",
        "icon": "/icons/platform.svg",
        "$ref": "config/navigation/platform.json"
      },
      {
        "tab": "Dev Tools",
        "icon": "/icons/dev-tools.svg",
        "menu": [
          {
            "item": "APIs",
            "icon": "/icons/apis.svg",
            "$ref": "config/navigation/apis.json"
          },
          {
            "item": "SDKs",
            "icon": "/icons/sdks.svg",
            "$ref": "config/navigation/sdk-libraries.json"
          },
          {
            "item": "Events Catalog",
            "icon": "/icons/events-catalog.svg",
            "$ref": "config/navigation/generated/events-catalog.en.json"
          },
          {
            "item": "Universal Components",
            "icon": "/icons/universal-components.svg",
            "$ref": "config/navigation/universal-components.json"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/docs/images/logo/light.svg",
    "dark": "/docs/images/logo/dark.svg",
    "href": "https://auth0.com/docs/"
  },
  "favicon": "/docs/images/logo/favicon.svg",
  "footer": {
    "socials": {
      "x-twitter": "https://x.com/auth0",
      "github": "https://github.com/auth0",
      "linkedin": "https://www.linkedin.com/company/auth0"
    },
    "links": [
      {
        "header": "Developers",
        "items": [
          {
            "label": "Developer Hub",
            "href": "https://developer.auth0.com"
          },
          {
            "label": "Code Samples & Guides",
            "href": "https://developer.auth0.com/resources"
          },
          {
            "label": "Zero Index Newsletter",
            "href": "https://auth0.com/blog/newsletter"
          },
          {
            "label": "Blog",
            "href": "https://auth0.com/blog"
          },
          {
            "label": "Changelog",
            "href": "https://auth0.com/changelog"
          }
        ]
      },
      {
        "header": "Docs",
        "items": [
          {
            "label": "Documentation",
            "href": "https://auth0.com/docs"
          },
          {
            "label": "Quickstarts",
            "href": "https://auth0.com/docs/quickstarts"
          },
          {
            "label": "APIs",
            "href": "https://auth0.com/docs/api"
          },
          {
            "label": "SDK Libraries",
            "href": "https://auth0.com/docs/libraries"
          },
          {
