{
  "options": {
    "experimentalClearLocaleDirs": true,
    "mintlify": {
      "inferTitleFromFilename": true
    },
    "jsonSchema": {
      "./docs.json": {
        "preset": "mintlify-hide-default"
      }
    },
    "docsUrlPattern": "/[locale]",
    "docsImportPattern": "/snippets/[locale]",
    "generateRedirects": "./docs.json",
    "experimentalLocalizeStaticImports": true,
    "experimentalLocalizeStaticUrls": true,
    "experimentalLocalizeRelativeAssets": true,
    "docsHideDefaultLocaleImport": true,
    "experimentalHideDefaultLocale": true,
    "experimentalAddHeaderAnchorIds": "mintlify"
  },
  "files": {
    "json": {
      "include": [
        "./docs/oas/authentication/authentication-api-oas.json",
        "./docs/oas/events/events-schema.json",
        "./docs/oas/management/v2/management-api-oas.json",
        "./docs/oas/myaccount/myaccount-api-oas.json",
        "./docs/oas/myorganization/myorganization-api-oas.json",
        "./docs/oas/tenant-logs/logs-schema.json",
        "./docs.json"
      ],
      "transform": [
        {
          "match": "^docs/oas/authentication/authentication-api-oas.json$",
          "replace": "{locale}/docs/oas/authentication/authentication-api-oas.json"
        },
        {
          "match": "^docs/oas/events/events-schema.json$",
          "replace": "{locale}/docs/oas/events/events-schema.json"
        },
        {
          "match": "^docs/oas/management/v2/management-api-oas.json$",
          "replace": "{locale}/docs/oas/management/v2/management-api-oas.json"
        },
        {
          "match": "^docs/oas/myaccount/myaccount-api-oas.json$",
          "replace": "{locale}/docs/oas/myaccount/myaccount-api-oas.json"
        },
        {
          "match": "^docs/oas/myorganization/myorganization-api-oas.json$",
          "replace": "{locale}/docs/oas/myorganization/myorganization-api-oas.json"
        },
        {
          "match": "^docs/oas/tenant-logs/logs-schema.json$",
          "replace": "{locale}/docs/oas/tenant-logs/logs-schema.json"
        }
      ]
    },
    "mdx": {
      "include": ["./**/*.mdx", "./**/*.md"],
      "transform": {
        "match": "^(snippets/)?(.*)$",
        "replace": "$1{locale}/$2"
      },
      "exclude": [
        "./[locales]/**/*.mdx",
        "./snippets/[locales]/**/*.mdx",
        "./[locales]/**/*.md",
        "./snippets/[locales]/**/*.md",
        "./**/README.md",
        "./**/LICENSE.md",
        "./**/COPYING.md",
        "./**/NOTICE.md",
        "./**/CHANGELOG.md",
        "./**/HISTORY.md",
        "./**/CODE_OF_CONDUCT.md",
        "./**/CONTRIBUTING.md",
        "./**/SECURITY.md",
        "./**/GOVERNANCE.md",
        "./**/AGENTS.md",
        "./**/OWNERS.md",
        "./**/MAINTAINERS.md"
      ]
    }
  },
  "locales": ["fr", "es", "ja"],
  "defaultLocale": "en",
  "$schema": "https://assets.gtx.dev/config-schema.json"
}

