{
  "options": {
    "experimentalClearLocaleDirs": true,
    "mintlify": {
      "inferTitleFromFilename": true,
      "openapi": {
        "files": [
          "./docs/oas/authentication/authentication-api-oas.json",
          "./docs/oas/events/events-schema.json",
          "./docs/oas/management/v2/management-api-oas.json",
          "./docs/oas/myaccount/myaccount-api-oas.json",
          "./docs/oas/myorganization/myorganization-api-oas.json",
          "./docs/oas/tenant-logs/logs-schema.json"
        ]
      }
    },
    "jsonSchema": {
      "./docs.json": {
        "preset": "mintlify-hide-default"
      },
      "./docs/oas/authentication/authentication-api-oas.json": {
        "preset": "openapi"
      },
      "./docs/oas/events/events-schema.json": {
        "preset": "openapi"
      },
      "./docs/oas/management/v2/management-api-oas.json": {
        "preset": "openapi"
      },
      "./docs/oas/myaccount/myaccount-api-oas.json": {
        "preset": "openapi"
      },
      "./docs/oas/myorganization/myorganization-api-oas.json": {
        "preset": "openapi"
      },
      "./docs/oas/tenant-logs/logs-schema.json": {
        "preset": "openapi"
      }
    },
    "docsUrlPattern": "/docs/[locale]",
    "docsImportPattern": "/snippets/[locale]",
    "generateRedirects": "./docs.json",
    "experimentalLocalizeStaticImports": true,
    "experimentalLocalizeStaticUrls": true,
    "experimentalLocalizeRelativeAssets": true,
    "docsHideDefaultLocaleImport": true,
    "experimentalHideDefaultLocale": true,
    "experimentalAddHeaderAnchorIds": "mintlify"
  },
  "files": {
    "json": {
      "include": [
        "./docs/oas/authentication/authentication-api-oas.json",
        "./docs/oas/events/events-schema.json",
        "./docs/oas/management/v2/management-api-oas.json",
        "./docs/oas/myaccount/myaccount-api-oas.json",
        "./docs/oas/myorganization/myorganization-api-oas.json",
        "./docs/oas/tenant-logs/logs-schema.json"
      ],
      "transform": {
        "match": "^(docs\/oas)/(.*)",
        "replace": "$1/{locale}/$2"
      }
    },
    "mdx": {
      "include": ["./docs/**/*.mdx", "./snippets/**/*.mdx"],
      "transform": {
        "match": "^(docs|snippets)/(.*)$",
        "replace": "$1/{locale}/$2"
      },
      "exclude": [
        "./docs/[locales]/**/*.mdx",
        "./snippets/[locales]/**/*.mdx",
        "./**/README.md",
        "./**/LICENSE.md",
        "./**/COPYING.md",
        "./**/NOTICE.md",
        "./**/CHANGELOG.md",
        "./**/HISTORY.md",
        "./**/CODE_OF_CONDUCT.md",
        "./**/CONTRIBUTING.md",
        "./**/SECURITY.md",
        "./**/GOVERNANCE.md",
        "./**/AGENTS.md",
        "./**/OWNERS.md",
        "./**/MAINTAINERS.md"
      ]
    }
  },
  "locales": ["fr-CA", "es"],
  "defaultLocale": "en",
  "$schema": "https://assets.gtx.dev/config-schema.json"
}
